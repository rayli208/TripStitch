rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Music tracks (public read, no client writes)
    match /music/{allPaths=**} {
      allow read: if true;
    }

    // User uploads (logo + avatar) — only the owner can write, anyone can read
    // Paths: /users/{uid}/logo.{ext}, /users/{uid}/avatar.{ext}
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Trip cover images — public read, only trip owner can write
    match /trips/{tripId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && firestore.get(/databases/(default)/documents/trips/$(tripId)).data.userId == request.auth.uid;
    }
  }
}
